---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Huynh Thien Tung's developer blog" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const navLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/tags', label: 'Tags' },
  { href: '/categories', label: 'Categories' },
  { href: 'https://huynhthientung.com', label: 'About', external: true, hideMobile: true },
];
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Prevent flash of wrong theme — must run before paint -->
    <script is:inline>
      const t = localStorage.getItem('theme') ?? 'dark';
      document.documentElement.dataset.theme = t;
    </script>
  </head>

  <body class="bg-white dark:bg-zinc-950 text-zinc-900 dark:text-zinc-300 font-sans antialiased min-h-screen flex flex-col">

    <!-- Sticky header -->
    <header class="sticky top-0 z-40 border-b border-zinc-200 dark:border-zinc-800 bg-white/80 dark:bg-zinc-950/80 backdrop-blur-md">
      <nav class="max-w-4xl mx-auto px-6 h-14 flex items-center justify-between">
        <a
          href="/"
          class="font-mono font-bold text-zinc-900 dark:text-zinc-200 hover:text-blue-600 dark:hover:text-blue-400 transition-colors text-sm"
        >
          tung.dev
        </a>

        <div class="flex items-center gap-1">
          <ul class="flex items-center">
            {navLinks.map(({ href, label, external, hideMobile }) => (
              <li class={hideMobile ? 'hidden md:block' : ''}>
                <a
                  href={href}
                  class="px-3 py-1.5 text-sm text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-200 rounded-md hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors"
                  {...(external ? { target: '_blank', rel: 'noopener' } : {})}
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
          <ThemeToggle />
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-zinc-200 dark:border-zinc-800 mt-24">
      <div class="max-w-4xl mx-auto px-6 py-8 text-center text-sm text-zinc-500 dark:text-zinc-400">
        <p>
          &copy; {new Date().getFullYear()} Huynh Thien Tung. All rights reserved.
          &nbsp;·&nbsp;
          <a
            href="https://huynhthientung.com"
            target="_blank"
            rel="noopener"
            class="hover:text-zinc-900 dark:hover:text-zinc-200 transition-colors"
          >
            huynhthientung.com ↗
          </a>
        </p>
      </div>
    </footer>
  </body>
</html>

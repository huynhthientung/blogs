---
import TagBadge from './TagBadge.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
  category?: string;
  coverImage?: string;
  coverAlt?: string;
}

const { title, description, pubDate, tags, slug, category, coverImage, coverAlt } = Astro.props;
const href = `/blog/${slug}`;
const date = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="relative group border border-zinc-200 dark:border-zinc-800 rounded-2xl overflow-hidden
                 bg-white dark:bg-zinc-900
                 hover:border-zinc-300 dark:hover:border-zinc-700
                 hover:shadow-lg dark:hover:shadow-zinc-900/50
                 transition-all duration-200">
  {coverImage && (
    <div class="overflow-hidden aspect-[2/1]">
      <img
        src={coverImage}
        alt={coverAlt ?? title}
        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
        loading="lazy"
        decoding="async"
      />
    </div>
  )}

  <div class="p-6">
    <!-- Meta: date + optional category -->
    <div class="flex items-center gap-2 text-xs text-zinc-500 dark:text-zinc-400 font-medium mb-3">
      <time datetime={pubDate.toISOString()}>{date}</time>
      {category && (
        <>
          <span aria-hidden="true">·</span>
          <a
            href={`/categories/${encodeURIComponent(category.toLowerCase().replace(/\s+/g, '-'))}`}
            class="relative z-10 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
          >
            {category}
          </a>
        </>
      )}
    </div>

    <h2 class="text-lg font-semibold leading-snug text-zinc-900 dark:text-zinc-200 mb-2
               group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
      <a href={href} class="after:absolute after:inset-0">{title}</a>
    </h2>

    <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed line-clamp-2 mb-4">
      {description}
    </p>

    {tags.length > 0 && (
      <div class="relative z-10 flex flex-wrap gap-1.5">
        {tags.map(tag => <TagBadge {tag} />)}
      </div>
    )}
  </div>
</article>

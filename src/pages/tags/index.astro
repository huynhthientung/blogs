---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);

// Build tag → count map, sorted by count desc then alpha
const tagMap = posts.reduce<Record<string, number>>((acc, post) => {
  for (const tag of post.data.tags) {
    acc[tag] = (acc[tag] ?? 0) + 1;
  }
  return acc;
}, {});

const tags = Object.entries(tagMap).sort(([a, ca], [b, cb]) => cb - ca || a.localeCompare(b));
---

<BaseLayout title="Tags — Huynh Thien Tung" description="Browse posts by tag">
  <div class="max-w-4xl mx-auto px-6 py-14">

    <div class="mb-12">
      <h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-3">
        Tags
      </h1>
      <p class="text-zinc-500 dark:text-zinc-400">
        {tags.length} tag{tags.length !== 1 ? 's' : ''} across {posts.length} post{posts.length !== 1 ? 's' : ''}.
      </p>
    </div>

    {tags.length === 0 ? (
      <p class="text-zinc-500 dark:text-zinc-400">No tags yet.</p>
    ) : (
      <div class="flex flex-wrap gap-3">
        {tags.map(([tag, count]) => (
          <a
            href={`/tags/${encodeURIComponent(tag)}`}
            class="group flex items-center gap-2 px-4 py-2 rounded-xl border border-zinc-200 dark:border-zinc-800
                   bg-white dark:bg-zinc-900
                   hover:border-green-500 dark:hover:border-green-600
                   hover:bg-green-50 dark:hover:bg-green-950/30
                   transition-all duration-150"
          >
            <span class="text-sm font-medium text-zinc-700 dark:text-zinc-300 group-hover:text-green-700 dark:group-hover:text-green-400 transition-colors">
              #{tag}
            </span>
            <span class="text-xs font-semibold tabular-nums px-1.5 py-0.5 rounded-full
                         bg-zinc-100 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-400
                         group-hover:bg-green-100 dark:group-hover:bg-green-900/50
                         group-hover:text-green-700 dark:group-hover:text-green-400
                         transition-colors">
              {count}
            </span>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('blog', ({ data }) => !data.draft);

// Build category → count map
const categoryMap = posts.reduce<Record<string, number>>((acc, post) => {
  if (post.data.category) {
    acc[post.data.category] = (acc[post.data.category] ?? 0) + 1;
  }
  return acc;
}, {});

const categories = Object.entries(categoryMap).sort(([, a], [, b]) => b - a);

const toSlug = (name: string) => name.toLowerCase().replace(/\s+/g, '-');
---

<BaseLayout title="Categories — Tung Huynh" description="Browse posts by category">
  <div class="max-w-4xl mx-auto px-6 py-14">

    <div class="mb-12">
      <h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-3">
        Categories
      </h1>
      <p class="text-zinc-500 dark:text-zinc-400">
        {categories.length} categor{categories.length !== 1 ? 'ies' : 'y'} across {posts.length} post{posts.length !== 1 ? 's' : ''}.
      </p>
    </div>

    {categories.length === 0 ? (
      <p class="text-zinc-500 dark:text-zinc-400">No categories yet. Add a <code class="font-mono text-sm">category</code> field to your posts.</p>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {categories.map(([name, count]) => (
          <a
            href={`/categories/${toSlug(name)}`}
            class="group flex flex-col justify-between p-6 rounded-2xl border border-zinc-200 dark:border-zinc-800
                   bg-white dark:bg-zinc-900 min-h-[120px]
                   hover:border-blue-400 dark:hover:border-blue-500
                   hover:shadow-md dark:hover:shadow-zinc-900/50
                   transition-all duration-200"
          >
            <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-200
                       group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
              {name}
            </h2>
            <div class="flex items-center justify-between mt-4">
              <span class="text-sm text-zinc-500 dark:text-zinc-400">
                {count} post{count !== 1 ? 's' : ''}
              </span>
              <span class="text-zinc-400 dark:text-zinc-600 group-hover:text-blue-500 dark:group-hover:text-blue-400 group-hover:translate-x-0.5 transition-all">
                →
              </span>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  const toSlug = (name: string) => name.toLowerCase().replace(/\s+/g, '-');

  const categoryNames = [
    ...new Set(posts.map(p => p.data.category).filter((c): c is string => Boolean(c))),
  ];

  return categoryNames.map(name => ({
    params: { category: toSlug(name) },
    props: {
      name,
      posts: posts
        .filter(p => p.data.category === name)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { name, posts } = Astro.props;
---

<BaseLayout
  title={`${name} — Categories — Huynh Thien Tung`}
  description={`All posts in the ${name} category`}
>
  <div class="max-w-4xl mx-auto px-6 py-14">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-zinc-500 dark:text-zinc-400 mb-10">
      <a href="/categories" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">Categories</a>
      <span aria-hidden="true">/</span>
      <span class="text-zinc-900 dark:text-zinc-200 font-medium">{name}</span>
    </nav>

    <div class="mb-12">
      <h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-3">
        {name}
      </h1>
      <p class="text-zinc-500 dark:text-zinc-400">
        {posts.length} post{posts.length !== 1 ? 's' : ''}
      </p>
    </div>

    {posts.length === 0 ? (
      <p class="text-zinc-500 dark:text-zinc-400">No posts in this category yet.</p>
    ) : (
      <div class="grid gap-5 sm:grid-cols-2">
        {posts.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            category={post.data.category}
            slug={post.id.replace(/\.mdx?$/, '')}
            coverImage={post.data.coverImage}
            coverAlt={post.data.coverAlt}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
